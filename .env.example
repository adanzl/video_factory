# LLM
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_MAX_TOKENS=32768
# DEEPSEEK_THINKING=false
# LLM_IMAGE_PROMPT_BATCH_SIZE=4

# 百炼：文生图 / Qwen-VL / CosyVoice TTS（共用 Key）
DASHSCOPE_API_KEY=

# TTS 可选单独 Key；未设则使用 DASHSCOPE_API_KEY
# TTS_API_KEY=
DASHSCOPE_WS_URI=wss://dashscope.aliyuncs.com/api-ws/v1/inference/
TTS_VOICE=cosyvoice-v3.5-flash-leo-60621bdce780434ab0734555e5196d7d
# TTS_MODEL=cosyvoice-v3-flash
# 儿童科普线（默认）：TTS_INSTRUCT_PRESET=science_child
# 成年科普线：longanhuan + TTS_INSTRUCT_PRESET=science_adult
TTS_INSTRUCT_PRESET=science_child
TTS_SPEECH_RATE=1.15
TTS_VOLUME=50
# 单 job 内分镜 TTS 并发数（默认 3，设为 1 则串行）
TTS_MAX_WORKERS=3

# 无 API Key 时自动 MOCK_MODE；也可显式开启
MOCK_MODE=true
SKIP_PUBLISH_DEFAULT=true

# 讲解人 IP（资产就绪后再开）
HOST_ENABLED=false

# 可灵升级（默认关）
KLING_UPGRADE_ENABLED=false

IMAGE_PROVIDER=z_image_t2i
# z_image_t2i | wan_t2i | sd15_t2i | agnes_t2i
IMAGE_MAX_WORKERS=2
# 错峰发起间隔（秒）；Agnes 并发时每隔 N 秒启动下一张，避免 429
IMAGE_SUBMIT_INTERVAL_SEC=20

# Agnes AI 文生图（IMAGE_PROVIDER=agnes_t2i）
# 当前推荐：IMAGE_MAX_WORKERS=2，IMAGE_SUBMIT_INTERVAL_SEC=20
# 优先 AGNES_FREE_API_KEY，限流/配额耗尽后自动切换 AGNES_API_KEY
# AGNES_FREE_API_KEY=
# AGNES_API_KEY=
# AGNES_API_BASE_URL=https://apihub.agnes-ai.com/v1
# AGNES_IMAGE_MODEL=agnes-image-2.1-flash
# AGNES_IMAGE_SIZE=720*1280
# AGNES_HTTP_MAX_RETRIES=5
# AGNES_SUBMIT_INTERVAL_SEC=12
# AGNES_HTTP_CONNECT_TIMEOUT_SEC=15
# AGNES_HTTP_SUBMIT_READ_TIMEOUT_SEC=60
# AGNES_HTTP_POLL_READ_TIMEOUT_SEC=30
# Agnes 图生视频（video_provider=agnes_i2v，实际调用文生视频 API，合并 image_prompt+motion_prompt）
# AGNES_VIDEO_MODEL=agnes-video-v2.0
# AGNES_VIDEO_FRAME_RATE=24
# AGNES_VIDEO_POLL_INTERVAL_SEC=5
# AGNES_VIDEO_POLL_MAX_ATTEMPTS=120
# AGNES_VIDEO_TASK_MAX_RETRIES=2
# AGNES_VIDEO_SUBMIT_MAX_RETRIES=2
# AGNES_VIDEO_DOWNLOAD_TIMEOUT_SEC=300

# 本地 SD1.5（IMAGE_PROVIDER=sd15_t2i 时生效；需先启动 deploy/sd15 WebUI）
# SD_API_URL=http://127.0.0.1:9101
# SD_BUSINESS=science
# SD_IMAGE_SIZE=360*640
# SD_TIMEOUT_SEC=600

# Z-Image（默认）：关 prompt_extend=0.1元/张，开=0.2元/张
Z_IMAGE_MODEL=z-image-turbo
Z_IMAGE_SIZE=720*1280
Z_IMAGE_PROMPT_EXTEND=false
# --- 视频成片（竖屏 9:16）：片头 / 字幕 / FFmpeg 合成 ---
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
# 也可用 VIDEO_SIZE=1080*1920

# --- 投稿封面（横屏 16:9）：与视频分辨率独立 ---
COVER_WIDTH=1280
COVER_HEIGHT=720
# 也可用 COVER_SIZE=1280*720

WAN_MODEL=wanx2.1-t2i-turbo
# 万相 API 出图尺寸（可与成片/封面逻辑分辨率不同）
WAN_IMAGE_SIZE=720*1280
WAN_COVER_SIZE=1280*720
MOTION_PRESET=ken_burns_slow
# FFmpeg 编码加速：veryfast + CRF 20 为默认；量产可改 FFMPEG_PRESET=medium FFMPEG_CRF=18
FFMPEG_PRESET=veryfast
FFMPEG_CRF=20
# FFMPEG_SUBTITLE_CRF=20
# Linux AMD APU（如 Radeon 780M）硬件编码，需 /dev/dri/renderD128 可访问
# FFMPEG_HWACCEL=vaapi
# FFMPEG_VAAPI_DEVICE=/dev/dri/renderD128
# FFMPEG_VAAPI_CODEC=h264_vaapi
# 分镜动效：ffmpeg（Ken Burns）| wan_i2v | agnes_i2v
CLIP_PROVIDER=ffmpeg
# WAN_I2V_MODEL=wanx2.1-i2v-turbo
# WAN_I2V_RESOLUTION=720P
# WAN_I2V_PROMPT_EXTEND=true
# CLIP_SUBMIT_INTERVAL_SEC=3
# 百炼 HTTP 重试（429/5xx）；图生视频整任务重试与轮询上限
# DASHSCOPE_HTTP_MAX_RETRIES=2
# WAN_I2V_TASK_MAX_RETRIES=1
# WAN_I2V_POLL_MAX_ATTEMPTS=60
# WAN_T2I_POLL_MAX_ATTEMPTS=45

# TTS / 音频质检与响度归一
AUDIO_TARGET_LUFS=-16
AUDIO_TRUE_PEAK=-1.5
AUDIO_SILENCE_NOISE_DB=-40
AUDIO_MAX_SILENCE_GAP_SEC=1.5
AUDIO_MAX_EDGE_SILENCE_SEC=0.8
TTS_CUE_DURATION_TOLERANCE_SEC=0.8
AUDIO_LOUDNESS_TOLERANCE_LU=2.5
# 成片时长：开发默认 min 55s；strict 模式 55～130s（1～2 分钟短科普）
# material 线若基底较长，请设 FINAL_MAX_DURATION_SEC=900
# FINAL_DURATION_STRICT=true
# TARGET_FINAL_DURATION_SEC=90
# INTRO_DURATION_BUDGET_SEC=2
# FINAL_MIN_DURATION_SEC=55
# FINAL_MAX_DURATION_SEC=130

# 片头背景图（默认 backend/res/bg/bg1.png）
# INTRO_BG_PATH=./backend/res/bg/bg1.png
# HOST_INTRO_PATH=./backend/res/host/intro.png
# HOST_BOY_PATH=./backend/res/host/boy.png
# HOST_GIRL_PATH=./backend/res/host/girl.png
# INTRO_SHOUT_PATH=./backend/res/audio/intro_shout.mp3
BRAND_NAME=昭墨百科
INTRO_TTS_RATE=1.25
INTRO_TTS_PITCH=1.15
MAX_TITLE_LENGTH=16

# 口播语速估算（字/秒，用于字数↔时长对齐；与 CosyVoice 实际语速一致）
# NARRATION_CHARS_PER_SEC=5
# 单镜口播上限（秒），传给 LLM 动态切分分镜；0=不约束单镜时长
SEGMENT_TARGET_SEC=16

# B 站（样片可不配）
BILI_CLIENT_ID=
BILI_CLIENT_SECRET=
BILI_ACCESS_TOKEN=

# 素材片段搜索（聚合 API，不入库；NASA 无需 Key）
# PEXELS_API_KEY=
# PIXABAY_API_KEY=
# CLIP_SEARCH_TIMEOUT_SEC=12

VIDEO_DATA_DIR=./data/media
# 媒体文件访问允许的额外根目录（Linux 挂载盘，对齐 MyTodo ALLOWED_DIR=/mnt）
ALLOWED_DIR=/mnt
LOG_DIR=./logs
# 总日志 worker.log / app.log 按自然日切割，默认保留 3 天（含当天）
# LOG_RETENTION_DAYS=3
SQLITE_PATH=./data/data.db
# REDIS_URL=redis://localhost:6379/0

ENABLE_SCHEDULER=false

# 服务器
# ENV=development
# HOST=0.0.0.0
# PORT=9002
# 跨域来源（逗号分隔）；前端 withCredentials 需配置具体 origin，不能用 *
CORS_ORIGINS=https://leo-zhao.natapp4.cc,http://localhost:5175,http://127.0.0.1:5175
