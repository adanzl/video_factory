{
    "cSpell.words": [
        "anullsrc",
        "BILI",
        "COSYVOICE",
        "DASHSCOPE",
        "dbtp",
        "DEEPSEEK",
        "demuxer",
        "ffprobe",
        "Freetype",
        "KLING",
        "lavfi",
        "libass",
        "libmp",
        "libx",
        "longwan",
        "loudnorm",
        "lufs",
        "PUNCT",
        "Qwen",
        "tpad",
        "vout",
        "zoompan"
    ],
    "cSpell.useGitignore": true,
    "cSpell.ignorePaths": [
        "data/**",
        "**/*.db",
        "**/*_cache/**",
    ],
    "cSpell.enabledFileTypes": {
        "dotenv": true,
        "properties": true
    },
    "cSpell.ignoreRegExpList": [
        "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*\\(", // 忽略函数调用
        "\\b[a-zA-Z_][a-zA-Z0-9_]*\\.[a-zA-Z_][a-zA-Z0-9_]*\\s*", // 忽略方法调用
        "^\\s*from\\s+\\S+\\s+import\\s+.+$", // 忽略 from xxx import xxx
        "^\\s*import\\s+.+$" // 忽略 import xxx
    ],
    // 解释器路径因系统/安装位置而异，勿写入仓库；首次用命令面板选 conda 环境 flask_env 即可
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",
    "python-envs.pythonProjects": [],
    "python.terminal.activateEnvInCurrentTerminal": true
}